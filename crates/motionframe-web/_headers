/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Worker assets live under a content-hashed directory (static/worker-<hash>/,
# see scripts/build-web-worker.sh), so — like the main app bundle — their URL
# changes whenever the worker changes. That makes immutable caching correct: a
# returning visitor's new main app references a new worker dir it hasn't cached,
# so there's no stale-worker / new-app skew.
/*.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

/*.js
  Cache-Control: public, max-age=31536000, immutable

/static/worker-*/*
  Cross-Origin-Resource-Policy: same-origin

/index.html
  Cache-Control: no-cache
